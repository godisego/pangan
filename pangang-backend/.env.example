# API Keys
# Optional: leave blank and use the settings page / local config instead.
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
# Optional: Tushare fallback source for stronger A-share stats.
# Leave blank for open-source / public-source mode.
TUSHARE_TOKEN=
SHARED_AI_PROVIDER=zhipu
SHARED_AI_MODEL=glm-4.7-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Settings
FRONTEND_URL=http://localhost:3000

# Notification (Optional)
FEISHU_WEBHOOK=
WECOM_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_PROXY_URL=

# Scheduler
ENABLE_DAILY_SCHEDULER=false
DAILY_PUSH_TIME=08:00
DAILY_PUSH_TIMEZONE=Asia/Shanghai
DAILY_REPORT_TRIGGER_SECRET=
ALLOW_PUBLIC_NOTIFY_CONFIG=false
ALLOW_PUBLIC_NOTIFY_TEST=false
